rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userOwnsProfile(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function ownerSalonId(salonId) {
      return signedIn() && salonId == 'salon-' + request.auth.uid;
    }

    function salonHasOwner() {
      return resource.data.keys().hasAny(['ownerUid']) &&
        resource.data.ownerUid is string &&
        resource.data.ownerUid.size() > 0;
    }

    function ownerClaimsOwnSalon(salonId) {
      return ownerSalonId(salonId) &&
        !salonHasOwner() &&
        request.resource.data.ownerUid == request.auth.uid;
    }

    function barberClaimsOwnProfile() {
      return signedIn() &&
        resource.data.uid == null &&
        request.resource.data.uid == request.auth.uid &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.contact == resource.data.phone ||
         get(/databases/$(database)/documents/users/$(request.auth.uid))
          .data.email == resource.data.email) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['uid', 'updatedAt']);
    }

    match /users/{userId} {
      allow read, update: if userOwnsProfile(userId);
      allow create: if signedIn() && request.auth.uid == userId;
    }

    match /salons/{salonId} {
      allow read: if true;
      allow create: if signedIn() &&
        request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if signedIn() &&
        (resource.data.ownerUid == request.auth.uid ||
         ownerClaimsOwnSalon(salonId));
    }

    match /barbers/{barberId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if signedIn() &&
        (resource.data.uid == request.auth.uid ||
         resource.data.ownerUid == request.auth.uid ||
         barberClaimsOwnProfile());
      allow delete: if signedIn() &&
        (resource.data.uid == request.auth.uid ||
         resource.data.ownerUid == request.auth.uid);
    }

    match /slotLocks/{slotLockId} {
      allow read: if true;
      allow create, update: if signedIn();
      allow delete: if false;
    }

    match /bookings/{bookingId} {
      allow create: if signedIn() &&
        request.resource.data.customerUid == request.auth.uid;
      allow read, update: if signedIn() &&
        (resource.data.customerUid == request.auth.uid ||
         resource.data.barberUid == request.auth.uid ||
         resource.data.ownerUid == request.auth.uid);
      allow delete: if false;
    }

    match /joinRequests/{requestId} {
      allow create: if signedIn() &&
        request.resource.data.requesterUid == request.auth.uid;
      allow read, update: if signedIn() &&
        (resource.data.requesterUid == request.auth.uid ||
         resource.data.ownerUid == request.auth.uid);
      allow delete: if false;
    }
  }
}
