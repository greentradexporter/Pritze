rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userOwnsProfile(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function barberClaimsOwnPhoneProfile() {
      return signedIn() &&
        resource.data.uid == null &&
        request.resource.data.uid == request.auth.uid &&
        request.auth.token.phone_number == resource.data.phone &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['uid', 'updatedAt']);
    }

    match /users/{userId} {
      allow read, update: if userOwnsProfile(userId);
      allow create: if signedIn() && request.auth.uid == userId;
    }

    match /salons/{salonId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if signedIn() &&
        resource.data.ownerUid == request.auth.uid;
    }

    match /barbers/{barberId} {
      allow read: if true;
      allow create: if signedIn();
      allow update: if signedIn() &&
        (resource.data.uid == request.auth.uid ||
         resource.data.ownerUid == request.auth.uid ||
         barberClaimsOwnPhoneProfile());
      allow delete: if signedIn() &&
        (resource.data.uid == request.auth.uid ||
         resource.data.ownerUid == request.auth.uid);
    }

    match /bookings/{bookingId} {
      allow create: if signedIn() &&
        request.resource.data.customerUid == request.auth.uid;
      allow read, update: if signedIn() &&
        (resource.data.customerUid == request.auth.uid ||
         resource.data.barberUid == request.auth.uid ||
         resource.data.ownerUid == request.auth.uid);
      allow delete: if false;
    }

    match /joinRequests/{requestId} {
      allow create: if signedIn() &&
        request.resource.data.requesterUid == request.auth.uid;
      allow read, update: if signedIn() &&
        (resource.data.requesterUid == request.auth.uid ||
         resource.data.ownerUid == request.auth.uid);
      allow delete: if false;
    }
  }
}
